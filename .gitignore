# --- Secrets & local env ---
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json
secrets/

# --- Disposable execution workspaces (see environments/EXECUTION_WORKSPACE_POLICY.md) ---
workdir/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.envrc

# --- Node ---
node_modules/

# --- Java / JVM ---
*.class
*.jar
!**/gradle/wrapper/*.jar
.gradle/
target/

# --- Notebooks ---
.ipynb_checkpoints/

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Heavy local experiment outputs (structure kept via .gitkeep) ---
# Note: upstream/ IS tracked (vendored working trees) so ChatGPT/plan sync can read code.
# Nested clone metadata is kept locally as .git_local/ and must NOT be committed.
results/native/**
!results/native/.gitkeep
results/common/**
!results/common/.gitkeep
datasets/native/**
!datasets/native/.gitkeep
datasets/common/**
!datasets/common/.gitkeep
graph_snapshots/**
!graph_snapshots/.gitkeep
papers/**
!papers/.gitkeep

# Nested git metadata of vendored upstream clones (local only)
upstream/**/.git_local/

# --- Local environment installs ---
environments/**/venv/
environments/**/.venv/
environments/**/node_modules/

# --- Model / HF caches ---
.cache/
**/huggingface/
**/transformers_cache/
*.bin
*.pt
*.pth
*.ckpt
*.onnx
*.gguf

# --- Coverage / test ---
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
