{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.lab/gold-evaluation-record",
  "title": "GoldEvaluationRecord",
  "type": "object",
  "required": [
    "protocol_version",
    "metric_contract_version",
    "dataset_view",
    "dataset_source_pin",
    "split",
    "item_id",
    "language",
    "question_hash",
    "gold_sparql_hash",
    "gold_query_form",
    "exclusion_status"
  ],
  "properties": {
    "protocol_version": {
      "type": "string"
    },
    "metric_contract_version": {
      "type": "string",
      "const": "0.1.0-documentary"
    },
    "dataset_view": {
      "type": "string"
    },
    "dataset_source_pin": {
      "type": "string"
    },
    "split": {
      "type": "string"
    },
    "item_id": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "question_hash": {
      "type": "string"
    },
    "gold_sparql_hash": {
      "type": "string"
    },
    "gold_query_form": {
      "type": "string"
    },
    "gold_projection_arity": {
      "type": [
        "integer",
        "null"
      ]
    },
    "graph_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "graph_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "graph_snapshot_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "gold_parse_status": {
      "type": "string"
    },
    "gold_safety_status": {
      "type": "string"
    },
    "gold_execution_status": {
      "type": "string"
    },
    "gold_result_type": {
      "type": "string"
    },
    "gold_result_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "gold_result_cardinality": {
      "type": [
        "integer",
        "null"
      ]
    },
    "gold_empty_result": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "oracle_manifest_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "exclusion_status": {
      "type": "string"
    },
    "exclusion_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "materialization_status": {
      "type": "string",
      "const": "GOLD_MATERIALIZATION_PENDING"
    }
  },
  "additionalProperties": true
}
