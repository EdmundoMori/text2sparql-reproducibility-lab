# .env.example — plantilla sin secretos.
# Copiar a .env (ignorado por git) y rellenar localmente.
# Nunca commitear claves reales.

# --- LLM APIs (usar solo si el método/auditoría lo requiere) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
HUGGINGFACE_TOKEN=

# --- Endpoints SPARQL (sobrescribir solo con justificación documentada) ---
DBPEDIA_SPARQL_ENDPOINT=https://dbpedia.org/sparql
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# --- Preferencias de ejecución del laboratorio ---
LAB_ROOT=
LAB_LOG_LEVEL=INFO
LAB_DISABLE_NETWORK=0
LAB_MAX_LLM_CALLS=
LAB_MAX_BUDGET_USD=

# --- Proxies opcionales ---
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
