@prefix ex: <https://is.gd/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
ex:4l6lWC a sh:SPARQLSelectExecutable, sh:SPARQLExecutable ;
    rdfs:label "ID43-3-1" ;
    rdfs:comment "Could you tell me which protein URI is annotated to bind the cofactor obo:CHEBI_58416?"@en ;
    sh:select """# Endpoint: https://rdfportal.org/sib/sparql
#           https://sparql.uniprot.org/sparql
# Description: Could you tell me which protein URI is annotated to bind the cofactor obo:CHEBI_58416?
# Parameter: cofactor: (example: obo:CHEBI_58416)

PREFIX core: <http://purl.uniprot.org/core/>
PREFIX chembl: <http://rdf.ebi.ac.uk/terms/chembl#>
PREFIX obo: <http://purl.obolibrary.org/obo/>

SELECT DISTINCT ?UniProt
WHERE {
    VALUES ?cofactor { obo:CHEBI_58416 }
    VALUES ?UniProt__class { core:Protein chembl:UniprotRef }
    ?UniProt a ?UniProt__class ;
        core:annotation / core:cofactor ?cofactor .
}
LIMIT 100
""" ;
    schema:target "https://sparql.uniprot.org/sparql".
