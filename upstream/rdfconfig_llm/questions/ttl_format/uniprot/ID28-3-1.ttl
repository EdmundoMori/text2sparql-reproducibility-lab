@prefix ex: <https://is.gd/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
ex:36CvvE a sh:SPARQLSelectExecutable, sh:SPARQLExecutable ;
    rdfs:label "ID28-3-1" ;
    rdfs:comment "What is the mass of the protein sequence encoded by ASA1?"@en ;
    sh:select """# Endpoint: https://rdfportal.org/sib/sparql
#           https://sparql.uniprot.org/sparql
# Description: What is the mass of the protein sequence encoded by ASA1?
# Parameter: uniprot_gene_name: (example: ASA1)

PREFIX core: <http://purl.uniprot.org/core/>
PREFIX chembl: <http://rdf.ebi.ac.uk/terms/chembl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?seq_mass
WHERE {
    VALUES ?uniprot_gene_name { "ASA1" }
    VALUES ?UniProt__class { core:Protein chembl:UniprotRef }
    ?UniProt a ?UniProt__class ;
        core:sequence / core:mass ?seq_mass ;
        core:encodedBy / skos:prefLabel ?uniprot_gene_name .
}
LIMIT 100
""" ;
    schema:target "https://sparql.uniprot.org/sparql".
