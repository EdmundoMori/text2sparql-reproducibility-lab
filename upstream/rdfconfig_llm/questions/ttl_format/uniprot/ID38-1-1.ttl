@prefix ex: <https://is.gd/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
ex:XGD8HQ a sh:SPARQLSelectExecutable, sh:SPARQLExecutable ;
    rdfs:label "ID38-1-1" ;
    rdfs:comment "Could you describe the subcellular localization of the gp23 protein in more detail?"@en ;
    sh:select """# Endpoint: https://rdfportal.org/sib/sparql
#           https://sparql.uniprot.org/sparql
# Description: Could you describe the subcellular localization of the gp23 protein in more detail?
# Parameter: uniprot_gene_name: (example: gp23)

PREFIX core: <http://purl.uniprot.org/core/>
PREFIX chembl: <http://rdf.ebi.ac.uk/terms/chembl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?location_desc
WHERE {
    VALUES ?uniprot_gene_name { "gp23" }
    VALUES ?UniProt__class { core:Protein chembl:UniprotRef }
    ?UniProt a ?UniProt__class ;
        core:encodedBy / skos:prefLabel ?uniprot_gene_name .
    OPTIONAL {
        ?UniProt core:annotation ?SubcellularLocationAnnotation .
        ?SubcellularLocationAnnotation a core:Subcellular_Location_Annotation ;
            rdfs:comment ?location_desc .
    }
}
LIMIT 100
""" ;
    schema:target "https://sparql.uniprot.org/sparql".
