@prefix ex: <https://is.gd/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
ex:k7Jugm a sh:SPARQLSelectExecutable, sh:SPARQLExecutable ;
    rdfs:label "ID42-5-1" ;
    rdfs:comment "ACE2 遺伝子によりコードされるタンパク質が補因子をどのように結合するかを記述したアノテーションはどのような内容ですか。"@ja ;
    sh:select """# Endpoint: https://rdfportal.org/sib/sparql
#           https://sparql.uniprot.org/sparql
# Description: ACE2 遺伝子によりコードされるタンパク質が補因子をどのように結合するかを記述したアノテーションはどのような内容ですか。
# Parameter: uniprot_gene_name: (example: ACE2)

PREFIX core: <http://purl.uniprot.org/core/>
PREFIX chembl: <http://rdf.ebi.ac.uk/terms/chembl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?cofactor_desc
WHERE {
    VALUES ?uniprot_gene_name { "ACE2" }
    VALUES ?UniProt__class { core:Protein chembl:UniprotRef }
    ?UniProt a ?UniProt__class ;
        core:encodedBy / skos:prefLabel ?uniprot_gene_name .
    OPTIONAL {
        ?UniProt core:annotation ?CofactorAnnotation .
        ?CofactorAnnotation a core:Cofactor_Annotation ;
            rdfs:comment ?cofactor_desc .
    }
}
LIMIT 100
""" ;
    schema:target "https://sparql.uniprot.org/sparql".
