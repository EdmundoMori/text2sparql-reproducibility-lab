@prefix ex: <https://is.gd/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
ex:rx0sUN a sh:SPARQLSelectExecutable, sh:SPARQLExecutable ;
    rdfs:label "ID26-2-1" ;
    rdfs:comment "Please describe the domain annotations of GPCR proteins and where each domain is located along the sequence."@en ;
    sh:select """# Endpoint: https://rdfportal.org/sib/sparql
#           https://sparql.uniprot.org/sparql
# Description: Please describe the domain annotations of GPCR proteins and where each domain is located along the sequence.
# Parameter: uniprot_gene_name: (example: GPCR)

PREFIX core: <http://purl.uniprot.org/core/>
PREFIX chembl: <http://rdf.ebi.ac.uk/terms/chembl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX faldo: <http://biohackathon.org/resource/faldo#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT DISTINCT ?domain_desc ?domain_begin ?domain_end
WHERE {
    VALUES ?uniprot_gene_name { "GPCR" }
    VALUES ?UniProt__class { core:Protein chembl:UniprotRef }
    ?UniProt a ?UniProt__class ;
        core:encodedBy / skos:prefLabel ?uniprot_gene_name .
    OPTIONAL {
        ?UniProt core:annotation ?DomainExtentAnnotation .
        ?DomainExtentAnnotation a core:Domain_Extent_Annotation ;
            rdfs:comment ?domain_desc ;
            core:range [
                a faldo:Region ;
                faldo:begin [
                    a faldo:Position ;
                    faldo:position ?domain_begin ;
                ] ;
                faldo:end [
                    a faldo:Position ;
                    faldo:position ?domain_end ;
                ] ;
            ] .
    }
}
LIMIT 100
""" ;
    schema:target "https://sparql.uniprot.org/sparql".
